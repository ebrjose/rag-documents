# Copia este archivo a `.env` y ajusta los valores.

# ── Ollama (mismo host) ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=gpt-oss:20b
OLLAMA_EMBED_MODEL=qwen3-embedding:4b
OLLAMA_CONTEXT_LENGTH=16384
OLLAMA_EMBED_CONTEXT_LENGTH=2048
OLLAMA_TEMPERATURE=0.2
# Timeouts (segundos). OLLAMA_CHAT_TIMEOUT_SECONDS vacío = sin límite.
OLLAMA_EMBED_TIMEOUT_SECONDS=120
OLLAMA_PING_TIMEOUT_SECONDS=5
OLLAMA_EMBED_BATCH_TIMEOUT_SECONDS=600

# ── Postgres (servicio Docker; puerto 5435 para no chocar con otros proyectos) ──
DATABASE_URL=postgresql://rag:rag@localhost:5435/rag_da

# ── Qdrant (servicio Docker; puerto 6335 para no chocar con otros proyectos) ──
QDRANT_URL=http://localhost:6335
QDRANT_COLLECTION=disposiciones

# ── Almacenamiento de PDFs ──
UPLOADS_DIR=./volumes/uploads

# ── Chunking ──
CHUNK_TARGET_TOKENS=500
CHUNK_OVERLAP_TOKENS=75

# ── Retrieval ──
TOP_K=8
DENSE_WEIGHT=0.7
SPARSE_WEIGHT=0.3

# ── Concurrencia ──
EMBED_CONCURRENCY=4
INGEST_CONCURRENCY=2

# ── OCR (Surya por GPU) ──
OCR_ENABLED=true
OCR_PROVIDER=surya
OCR_LANGUAGES=["es"]
OCR_DPI=200
OCR_MIN_TOTAL_CHARS=50
OCR_DEVICE=auto

# ── Servidor ──
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173
